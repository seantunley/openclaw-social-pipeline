# OpenClaw Social Pipeline — Environment Variables

# Anthropic API key for LLM content generation
ANTHROPIC_API_KEY=sk-ant-...

# Postiz integration (choose CLI or API mode in config)
POSTIZ_API_BASE_URL=https://app.postiz.com/api
POSTIZ_API_KEY=your-postiz-api-key

# Dashboard API server
API_PORT=3000
DASHBOARD_PORT=3001

# Database path (SQLite)
DATABASE_PATH=./data/social-pipeline.db

# Image generation (OpenClaw native or fal.ai fallback)
FAL_API_KEY=your-fal-key
IMGBB_API_KEY=your-imgbb-key

# Optional: OpenAI-compatible provider for LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=
