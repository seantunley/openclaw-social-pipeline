{
  "name": "@openclaw/social-pipeline",
  "version": "0.1.0",
  "description": "OpenClaw plugin for end-to-end social media content pipeline",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "postbuild": "bash scripts/sync-extension.sh",
    "dev": "concurrently -k -n tsc,sync -c blue,green \"tsc --watch --preserveWatchOutput\" \"node scripts/watch-sync.mjs\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist",
    "start:api": "node --env-file=.env dist/dashboard-api/server.js",
    "rebuild": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "social-media",
    "content-pipeline",
    "postiz",
    "marketing"
  ],
  "author": "Sean Tunley <sean@tunley.co.za>",
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fal-ai/client": "^1.9.5",
    "@fastify/cors": "^10.0.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
